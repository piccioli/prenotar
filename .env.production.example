# Template .env per produzione (copiare su server come .env e valorizzare i segreti).
# Non committare il .env reale. Riferimento: DEPLOY.md

APP_NAME="Prenotar"
APP_TAGLINE="Prenotar — Prenotazione torri di arrampicata GR Lombardia"
APP_VERSION=0.4.0
APP_VERSION_DATE=2026-05-11
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Rome
APP_URL=https://prenotar.montagnaservizi.it

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

# Obbligatorio dietro reverse proxy HTTPS (nginx, cloud LB). Usare IP specifici se le policy lo richiedono.
TRUSTED_PROXIES=*

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mariadb
# Con docker-compose.production.yml usare i nomi servizio; su VM senza Docker usare 127.0.0.1
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=prenotar
DB_USERNAME=prenotar
DB_PASSWORD=
# Password root MariaDB (solo container compose; non usata da Laravel)
DB_ROOT_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log

# Produzione: preferire s3 se gli allegati devono stare su object storage (vedi DEPLOY.md).
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=prenotar_prod_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Stack compose: Mailpit (servizio `mailpit`). UI: http://127.0.0.1:${MAILPIT_UI_PORT:-8025} sul server.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@prenotar.montagnaservizi.it"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

FALLBACK_EMAIL_DOMAIN=grlomct.it
