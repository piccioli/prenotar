# Template .env per ambiente staging (UAT).
# Copiare su server come .env.staging e valorizzare i segreti.
# Riferimento: DEPLOY.md §"Ambiente staging"
#
# Build + avvio:
#   docker compose -f docker-compose.staging.yml --env-file .env.staging build
#   docker compose -f docker-compose.staging.yml --env-file .env.staging up -d
#
# Seeding iniziale (OBBLIGATORIO dopo migrate):
#   docker compose -f docker-compose.staging.yml --env-file .env.staging exec app \
#     php artisan db:seed --class=LocalDevSeeder
#
# Reset completo staging (ATTENZIONE: cancella tutti i dati):
#   docker compose -f docker-compose.staging.yml --env-file .env.staging down -v

APP_NAME="Prenotar"
APP_TAGLINE="Prenotar — Prenotazione torri di arrampicata GR Lombardia"
APP_VERSION=0.8.0
APP_VERSION_DATE=2026-05-12
APP_ENV=staging
APP_KEY=
APP_DEBUG=false

# Build Docker: 1 = include require-dev (Faker, necessario per LocalDevSeeder demo prenotazioni)
COMPOSER_INSTALL_DEV=1
APP_TIMEZONE=Europe/Rome
APP_URL=https://staging.prenotar.montagnaservizi.it

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

# Obbligatorio dietro reverse proxy HTTPS
TRUSTED_PROXIES=*

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=prenotar_staging
DB_USERNAME=prenotar_staging
DB_PASSWORD=
# Password root MariaDB (solo container compose; non usata da Laravel)
DB_ROOT_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=prenotar_staging_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mailpit cattura tutte le email — nessun invio reale a provider esterni.
# UI Mailpit: http://127.0.0.1:8027 sul server (SSH tunnel o browser locale).
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@staging.prenotar.montagnaservizi.it"
MAIL_FROM_NAME="${APP_NAME}"

# Porta HTTP host (default 8081, no conflitto con prod su 80)
HTTP_PUBLISH=8081

# Porta UI Mailpit host (default 8027, no conflitto con prod su 8025)
MAILPIT_UI_PORT=8027

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

FALLBACK_EMAIL_DOMAIN=grlomct.it
